{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | Add-Content -Path '.github/hooks/agent_log.txt' -Encoding UTF8\""
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | Add-Content -Path '.github/hooks/agent_log.txt' -Encoding UTF8\""
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | Add-Content -Path '.github/hooks/agent_log.txt' -Encoding UTF8\""
      }
    ]
  }
}