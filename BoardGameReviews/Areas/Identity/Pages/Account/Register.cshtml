@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<section class="game-page game-form-page home-stage auth-stage">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <a class="auth-brand" asp-controller="Home" asp-action="Index">BoardGameReviews</a>
            <p class="eyebrow mb-2">Account</p>
            <h1 class="mb-0">Create Account</h1>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn home-btn-sub">Back to Home</a>
        </div>
    </div>

    <div class="game-card">
        <div class="card-header">Register</div>
        <div class="card-body">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.OIB" class="form-label"></label>
                    <input asp-for="Input.OIB" class="form-control" maxlength="11" />
                    <span asp-validation-for="Input.OIB" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.JMBG" class="form-label"></label>
                    <input asp-for="Input.JMBG" class="form-control" maxlength="13" />
                    <span asp-validation-for="Input.JMBG" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn home-btn-main">Register</button>
            </form>

            <div class="mt-3 auth-switch">
                <span class="auth-switch-text">Already have an account?</span>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn home-btn-sub">Log in</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
