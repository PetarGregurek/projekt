@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Register with " + @Model.ProviderDisplayName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<section class="game-page game-form-page home-stage auth-stage">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <a class="auth-brand" asp-controller="Home" asp-action="Index">BoardGameReviews</a>
            <p class="eyebrow mb-2">Account</p>
            <h1 class="mb-0">Complete Registration</h1>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn home-btn-sub">Back to Home</a>
        </div>
    </div>

    <div class="game-card">
        <div class="card-header">Associate your @Model.ProviderDisplayName account</div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-status mb-3" style="border-color:#e8a0a0;background:#fdf0f0;color:#7a1c1c;" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <p class="text-secondary mb-3">
                You're signing in with <strong>@Model.ProviderDisplayName</strong>.
                Please complete the fields below to finish creating your account.
            </p>

            <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.OIB" class="form-label"></label>
                    <input asp-for="Input.OIB" class="form-control" maxlength="11" placeholder="11 digits" />
                    <span asp-validation-for="Input.OIB" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.JMBG" class="form-label"></label>
                    <input asp-for="Input.JMBG" class="form-control" maxlength="13" placeholder="13 digits" />
                    <span asp-validation-for="Input.JMBG" class="text-danger"></span>
                </div>

                <button type="submit" class="btn home-btn-main">Create account</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
