@model BoardGameReviews.Models.GameIndexViewModel

@{
    ViewData["Title"] = "Games";
}

<section class="game-page game-list-page">
    <div class="game-hero mb-4">
        <p class="eyebrow mb-2">BoardGameReviews</p>
        <h1 class="mb-2">Games</h1>
        <div class="entity-nav d-flex flex-wrap gap-2">
            <a class="btn btn-sm game-btn-outline" href="#games">Games (@Model.Games.Count)</a>
            <a class="btn btn-sm game-btn-outline" asp-controller="Category" asp-action="Index">Categories</a>
            <a class="btn btn-sm game-btn-outline" asp-controller="GameType" asp-action="Index">Game Types</a>
            <a class="btn btn-sm game-btn-outline" asp-controller="Publisher" asp-action="Index">Publishers</a>
            <a class="btn btn-sm game-btn-outline" asp-controller="User" asp-action="Index">Users</a>
            <a class="btn btn-sm game-btn-outline" asp-controller="Review" asp-action="Index">Reviews</a>
            <a class="btn btn-sm game-btn-outline" asp-controller="Event" asp-action="Index">Events</a>
        </div>
    </div>

    <div id="games" class="entity-block game-table-wrap mb-4">
        <div class="entity-header">Games</div>
        <div class="table-responsive">
            <table class="table game-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Game</th>
                        <th>Year</th>
                        <th>Players</th>
                        <th>Difficulty</th>
                        <th>Type</th>
                        <th>Publisher</th>
                        <th>Category</th>
                        <th>Reviews</th>
                        <th>Avg. Rating</th>
                        <th>Events</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Games)
                    {
                        var difficultyClass = item.Game.Difficulty switch
                        {
                            Difficulty.Easy => "difficulty-easy",
                            Difficulty.Medium => "difficulty-medium",
                            _ => "difficulty-hard"
                        };

                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Game.Name</div>
                                <div class="small text-secondary">@item.Game.Description</div>
                            </td>
                            <td>@item.Game.YearPublished</td>
                            <td>@item.Game.MinPlayers - @item.Game.MaxPlayers</td>
                            <td><span class="difficulty-pill @difficultyClass">@item.Game.Difficulty</span></td>
                            <td>@item.GameTypeName</td>
                            <td>@item.PublisherName</td>
                            <td>@item.CategoryName</td>
                            <td>@item.ReviewCount</td>
                            <td>@(item.AverageRating?.ToString("0.0") ?? "N/A")</td>
                            <td>@item.EventCount</td>
                            <td>
                                <a asp-controller="Game" asp-action="Details" asp-route-id="@item.Game.Id" class="btn btn-sm game-btn-primary">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>