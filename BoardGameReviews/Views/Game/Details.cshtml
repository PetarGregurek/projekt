@model BoardGameReviews.Models.GameDetailsViewModel

@{
    ViewData["Title"] = "Game Details";
}

<section class="game-page game-details-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Game Details</p>
            <h1 class="mb-0">@Model.Game.Name</h1>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Game" asp-action="Index" class="btn game-btn-outline">Back to List</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card game-card h-100">
                <div class="card-header">Basic Information</div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.Game.Name</p>
                    <p><strong>Description:</strong> @Model.Game.Description</p>
                    <p><strong>Year:</strong> @Model.Game.YearPublished</p>
                    <p><strong>Players:</strong> @Model.Game.MinPlayers - @Model.Game.MaxPlayers</p>
                    <p><strong>Difficulty:</strong> @Model.Game.Difficulty</p>
                    <p><strong>Average Rating:</strong> @(Model.AverageRating?.ToString("0.0") ?? "N/A")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card game-card h-100">
                <div class="card-header">Related Entities</div>
                <div class="card-body">
                    <p><strong>Game Type:</strong> @Model.GameType?.Name</p>
                    <p><strong>Publisher:</strong> @Model.Publisher?.Name (@Model.Publisher?.Country)</p>
                    <p><strong>Category:</strong> @Model.Category?.Name</p>
                    <p><strong>Age Group:</strong> @Model.Category?.AgeGroup</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card game-card mb-4">
        <div class="card-header">Reviews and Users</div>
        <div class="card-body">
            @if (Model.Reviews.Count == 0)
            {
                <p class="mb-0">There are no reviews for this game.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table game-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Rating</th>
                                <th>Recommended</th>
                                <th>Comment</th>
                                <th>User</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Reviews)
                            {
                                <tr>
                                    <td>@item.Review.Title</td>
                                    <td>@item.Review.Rating</td>
                                    <td>@(item.Review.IsRecommended ? "Yes" : "No")</td>
                                    <td>@item.Review.Comment</td>
                                    <td>@item.User?.Username (@item.User?.Country)</td>
                                    <td>@item.Review.CreatedAt.ToString("d")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card game-card mb-4">
        <div class="card-header">Uploaded Files</div>
        <div class="card-body">
            @if (Model.Files.Count == 0)
            {
                <p class="mb-0">There are no uploaded files for this game.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table game-table game-files-table align-middle mb-0">
                        <colgroup>
                            <col style="width: 72%;" />
                            <col style="width: 28%;" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th class="text-start">File</th>
                                <th class="text-start">Uploaded</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in Model.Files)
                            {
                                <tr>
                                    <td class="text-start">
                                        <a href="@file.RelativePath" target="_blank" rel="noopener">@file.OriginalFileName</a>
                                    </td>
                                    <td class="text-start text-nowrap">@file.UploadedAt.ToLocalTime().ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card game-card">
        <div class="card-header">Events</div>
        <div class="card-body">
            @if (Model.Events.Count == 0)
            {
                <p class="mb-0">There are no events for this game.</p>
            }
            else
            {
                <ul class="list-group game-event-list">
                    @foreach (var evt in Model.Events)
                    {
                        <li class="list-group-item">
                            <strong>@evt.Name</strong><br />
                            @evt.StartDateTime.ToString("g") - @evt.EndDateTime.ToString("g")<br />
                            @evt.Location
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</section>

<style>
    .game-files-table thead th:nth-child(2),
    .game-files-table tbody td:nth-child(2),
    .game-files-table tbody td:last-child {
        text-align: left !important;
    }
</style>