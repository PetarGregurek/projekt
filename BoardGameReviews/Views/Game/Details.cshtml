@model BoardGameReviews.Models.GameDetailsViewModel

@{
    ViewData["Title"] = "Game Details";
}

<section class="game-page game-details-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Game Details</p>
            <h1 class="mb-0">@Model.Game.Name</h1>
        </div>
        <a asp-controller="Game" asp-action="Index" class="btn game-btn-outline">Natrag na listu</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card game-card h-100">
                <div class="card-header">Osnovni podaci</div>
                <div class="card-body">
                    <p><strong>Naziv:</strong> @Model.Game.Name</p>
                    <p><strong>Opis:</strong> @Model.Game.Description</p>
                    <p><strong>Godina:</strong> @Model.Game.YearPublished</p>
                    <p><strong>Igrači:</strong> @Model.Game.MinPlayers - @Model.Game.MaxPlayers</p>
                    <p><strong>Težina:</strong> @Model.Game.Difficulty</p>
                    <p><strong>Prosječna ocjena:</strong> @(Model.AverageRating?.ToString("0.0") ?? "N/A")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card game-card h-100">
                <div class="card-header">Povezani entiteti</div>
                <div class="card-body">
                    <p><strong>Tip igre:</strong> @Model.GameType?.Name</p>
                    <p><strong>Publisher:</strong> @Model.Publisher?.Name (@Model.Publisher?.Country)</p>
                    <p><strong>Kategorija:</strong> @Model.Category?.Name</p>
                    <p><strong>Dobna skupina:</strong> @Model.Category?.AgeGroup</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card game-card mb-4">
        <div class="card-header">Recenzije i korisnici</div>
        <div class="card-body">
            @if (Model.Reviews.Count == 0)
            {
                <p class="mb-0">Nema recenzija za ovu igru.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table game-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Naslov</th>
                                <th>Ocjena</th>
                                <th>Preporuka</th>
                                <th>Komentar</th>
                                <th>Korisnik</th>
                                <th>Datum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Reviews)
                            {
                                <tr>
                                    <td>@item.Review.Title</td>
                                    <td>@item.Review.Rating</td>
                                    <td>@(item.Review.IsRecommended ? "Da" : "Ne")</td>
                                    <td>@item.Review.Comment</td>
                                    <td>@item.User?.Username (@item.User?.Country)</td>
                                    <td>@item.Review.CreatedAt.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card game-card">
        <div class="card-header">Događaji</div>
        <div class="card-body">
            @if (Model.Events.Count == 0)
            {
                <p class="mb-0">Nema događaja za ovu igru.</p>
            }
            else
            {
                <ul class="list-group game-event-list">
                    @foreach (var evt in Model.Events)
                    {
                        <li class="list-group-item">
                            <strong>@evt.Name</strong><br />
                            @evt.StartDateTime.ToString("dd.MM.yyyy HH:mm") - @evt.EndDateTime.ToString("dd.MM.yyyy HH:mm")<br />
                            @evt.Location
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</section>