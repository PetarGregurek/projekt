@model BoardGameReviews.Models.EntityDetailsViewModel

@{
    ViewData["Title"] = "Entity Details";
}

<section class="game-page game-details-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Entity Details</p>
        </div>
        <a asp-controller="Game" asp-action="Index" class="btn game-btn-outline">Natrag na listu</a>
    </div>

    @if (Model.EntityType == "game" && Model.GameDetails != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card game-card h-100">
                    <div class="card-header">Osnovni podaci</div>
                    <div class="card-body">
                        <p><strong>Naziv:</strong> @Model.GameDetails.Game.Name</p>
                        <p><strong>Opis:</strong> @Model.GameDetails.Game.Description</p>
                        <p><strong>Godina:</strong> @Model.GameDetails.Game.YearPublished</p>
                        <p><strong>Igrači:</strong> @Model.GameDetails.Game.MinPlayers - @Model.GameDetails.Game.MaxPlayers</p>
                        <p><strong>Težina:</strong> @Model.GameDetails.Game.Difficulty</p>
                        <p><strong>Prosječna ocjena:</strong> @(Model.GameDetails.AverageRating?.ToString("0.0") ?? "N/A")</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card game-card h-100">
                    <div class="card-header">Povezani entiteti</div>
                    <div class="card-body">
                        <p><strong>Tip igre:</strong> @Model.GameDetails.GameType?.Name</p>
                        <p><strong>Publisher:</strong> @Model.GameDetails.Publisher?.Name (@Model.GameDetails.Publisher?.Country)</p>
                        <p><strong>Kategorija:</strong> @Model.GameDetails.Category?.Name</p>
                        <p><strong>Dobna skupina:</strong> @Model.GameDetails.Category?.AgeGroup</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card game-card mb-4">
            <div class="card-header">Recenzije i korisnici</div>
            <div class="card-body">
                @if (Model.GameDetails.Reviews.Count == 0)
                {
                    <p class="mb-0">Nema recenzija za ovu igru.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table game-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Naslov</th>
                                    <th>Ocjena</th>
                                    <th>Preporuka</th>
                                    <th>Komentar</th>
                                    <th>Korisnik</th>
                                    <th>Datum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.GameDetails.Reviews)
                                {
                                    <tr>
                                        <td>@item.Review.Title</td>
                                        <td>@item.Review.Rating</td>
                                        <td>@(item.Review.IsRecommended ? "Da" : "Ne")</td>
                                        <td>@item.Review.Comment</td>
                                        <td>@item.User?.Username (@item.User?.Country)</td>
                                        <td>@item.Review.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card game-card">
            <div class="card-header">Događaji</div>
            <div class="card-body">
                @if (Model.GameDetails.Events.Count == 0)
                {
                    <p class="mb-0">Nema događaja za ovu igru.</p>
                }
                else
                {
                    <ul class="list-group game-event-list">
                        @foreach (var evt in Model.GameDetails.Events)
                        {
                            <li class="list-group-item">
                                <strong>@evt.Name</strong><br />
                                @evt.StartDateTime.ToString("dd.MM.yyyy HH:mm") - @evt.EndDateTime.ToString("dd.MM.yyyy HH:mm")<br />
                                @evt.Location
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }

    @if (Model.EntityType == "category" && Model.Category != null)
    {
        <div class="card game-card mb-4">
            <div class="card-header">Category</div>
            <div class="card-body">
                <p><strong>Name:</strong> @Model.Category.Name</p>
                <p><strong>Description:</strong> @Model.Category.Description</p>
                <p><strong>Age group:</strong> @Model.Category.AgeGroup</p>
                <p><strong>Difficulty:</strong> @Model.Category.Difficulty</p>
                <p><strong>Popularity:</strong> @Model.Category.Popularity</p>
            </div>
        </div>

        <div class="card game-card">
            <div class="card-header">Games in Category</div>
            <div class="card-body">
                @if (Model.CategoryGames.Count == 0)
                {
                    <p class="mb-0">Nema igara u ovoj kategoriji.</p>
                }
                else
                {
                    <ul class="list-group game-event-list">
                        @foreach (var game in Model.CategoryGames)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span>@game.Name (@game.YearPublished)</span>
                                <a asp-controller="Game" asp-action="Details" asp-route-entity="game" asp-route-id="@game.Id" class="btn btn-sm game-btn-outline">Prikaži igru</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }

    @if (Model.EntityType == "gametype" && Model.GameType != null)
    {
        <div class="card game-card mb-4">
            <div class="card-header">Game Type</div>
            <div class="card-body">
                <p><strong>Name:</strong> @Model.GameType.Name</p>
                <p><strong>Description:</strong> @Model.GameType.Description</p>
            </div>
        </div>

        <div class="card game-card">
            <div class="card-header">Games by Type</div>
            <div class="card-body">
                @if (Model.GameTypeGames.Count == 0)
                {
                    <p class="mb-0">Nema igara za ovaj tip.</p>
                }
                else
                {
                    <ul class="list-group game-event-list">
                        @foreach (var game in Model.GameTypeGames)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span>@game.Name</span>
                                <a asp-controller="Game" asp-action="Details" asp-route-entity="game" asp-route-id="@game.Id" class="btn btn-sm game-btn-outline">Prikaži igru</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }

    @if (Model.EntityType == "publisher" && Model.Publisher != null)
    {
        <div class="card game-card mb-4">
            <div class="card-header">Publisher</div>
            <div class="card-body">
                <p><strong>Name:</strong> @Model.Publisher.Name</p>
                <p><strong>Country:</strong> @Model.Publisher.Country</p>
            </div>
        </div>

        <div class="card game-card">
            <div class="card-header">Published Games</div>
            <div class="card-body">
                @if (Model.PublisherGames.Count == 0)
                {
                    <p class="mb-0">Nema igara za ovog izdavača.</p>
                }
                else
                {
                    <ul class="list-group game-event-list">
                        @foreach (var game in Model.PublisherGames)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span>@game.Name</span>
                                <a asp-controller="Game" asp-action="Details" asp-route-entity="game" asp-route-id="@game.Id" class="btn btn-sm game-btn-outline">Prikaži igru</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }

    @if (Model.EntityType == "user" && Model.User != null)
    {
        <div class="card game-card mb-4">
            <div class="card-header">User</div>
            <div class="card-body">
                <p><strong>Username:</strong> @Model.User.Username</p>
                <p><strong>Email:</strong> @Model.User.Email</p>
                <p><strong>Country:</strong> @Model.User.Country</p>
                <p><strong>Age:</strong> @Model.User.Age</p>
            </div>
        </div>

        <div class="card game-card">
            <div class="card-header">User Reviews</div>
            <div class="card-body">
                @if (Model.UserReviews.Count == 0)
                {
                    <p class="mb-0">Korisnik nema recenzija.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table game-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Game</th>
                                    <th>Rating</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var review in Model.UserReviews)
                                {
                                    <tr>
                                        <td>@review.Review.Title</td>
                                        <td>@review.GameName</td>
                                        <td>@review.Review.Rating</td>
                                        <td>@review.Review.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.EntityType == "review" && Model.Review != null)
    {
        <div class="card game-card">
            <div class="card-header">Review</div>
            <div class="card-body">
                <p><strong>Title:</strong> @Model.Review.Title</p>
                <p><strong>Game:</strong> @Model.ReviewGame?.Name</p>
                <p><strong>User:</strong> @Model.ReviewUser?.Username</p>
                <p><strong>Rating:</strong> @Model.Review.Rating / 5</p>
                <p><strong>Recommended:</strong> @(Model.Review.IsRecommended ? "Da" : "Ne")</p>
                <p><strong>Date:</strong> @Model.Review.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Comment:</strong> @Model.Review.Comment</p>
            </div>
        </div>
    }

    @if (Model.EntityType == "event" && Model.Event != null)
    {
        <div class="card game-card">
            <div class="card-header">Event</div>
            <div class="card-body">
                <p><strong>Name:</strong> @Model.Event.Name</p>
                <p><strong>Game:</strong> @Model.EventGame?.Name</p>
                <p><strong>Start:</strong> @Model.Event.StartDateTime.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>End:</strong> @Model.Event.EndDateTime.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Location:</strong> @Model.Event.Location</p>
            </div>
        </div>
    }
</section>