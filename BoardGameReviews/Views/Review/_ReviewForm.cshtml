@model BoardGameReviews.Models.ReviewFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

@await Html.PartialAsync("_AiFormPrompt", new BoardGameReviews.Models.AiFormPromptViewModel
{
    EntityType = "review",
    Title = "Generate review data",
    Placeholder = "Example: Write a 5-star recommended review for an existing game by an existing user."
})

<div class="game-form-grid">
    <div>
        <label asp-for="Input.Title" class="form-label"></label>
        <input asp-for="Input.Title" class="form-control" />
        <span asp-validation-for="Input.Title" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Input.Rating" class="form-label"></label>
        <input asp-for="Input.Rating" class="form-control" />
        <span asp-validation-for="Input.Rating" class="text-danger"></span>
    </div>

    <div>
        @await Html.PartialAsync("_DateTimePicker", new BoardGameReviews.Models.DateTimePickerViewModel
        {
            FieldName = "Input.CreatedAt",
            FieldId = "Input_CreatedAt",
            Label = "Created At",
            Value = Model.Input.CreatedAt,
            IsRequired = false,
            ValidationMessage = ViewData.ModelState["Input.CreatedAt"]?.Errors.FirstOrDefault()?.ErrorMessage
        })
    </div>

    <div class="d-flex align-items-center gap-2 mt-4">
        <input asp-for="Input.IsRecommended" class="form-check-input" type="checkbox" />
        <label asp-for="Input.IsRecommended" class="form-label mb-0">Recommended</label>
    </div>

    <div class="game-form-grid__full">
        <label asp-for="Input.Comment" class="form-label"></label>
        <textarea asp-for="Input.Comment" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Comment" class="text-danger"></span>
    </div>

    <div>
        @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameReviews.Models.AutocompleteDropdownViewModel
        {
            InputName = "Input.GameId",
            InputId = "Input_GameId",
            Label = "Game",
            LookupUrl = Url.Action("Lookup", "Review", new { entityType = "game" }) ?? string.Empty,
            Placeholder = "Search game",
            SelectedId = Model.Input.GameId,
            SelectedLabel = Model.GameDisplayName,
            RequiredValidationMessage = "Select a game.",
            ValidationMessage = ViewData.ModelState["Input.GameId"]?.Errors.FirstOrDefault()?.ErrorMessage
        })
    </div>

    <div>
        @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameReviews.Models.AutocompleteDropdownViewModel
        {
            InputName = "Input.UserId",
            InputId = "Input_UserId",
            Label = "User",
            LookupUrl = Url.Action("Lookup", "Review", new { entityType = "user" }) ?? string.Empty,
            Placeholder = "Search user",
            SelectedId = Model.Input.UserId,
            SelectedLabel = Model.UserDisplayName,
            RequiredValidationMessage = "Select a user.",
            ValidationMessage = ViewData.ModelState["Input.UserId"]?.Errors.FirstOrDefault()?.ErrorMessage
        })
    </div>
</div>

<div class="game-form-actions">
    <button type="submit" class="btn game-btn-primary">@(Model.IsEdit ? "Save Changes" : "Create Review")</button>
    <a asp-action="Index" class="btn game-btn-outline">Back to List</a>
</div>
