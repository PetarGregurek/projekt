@model List<BoardGameReviews.Models.ReviewListItemViewModel>

@{
    ViewData["Title"] = "Reviews";
}

<section class="game-page game-list-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Entity Index</p>
            <h1 class="mb-0">Reviews</h1>
        </div>
        <a asp-controller="Game" asp-action="Index" class="btn game-btn-outline">Games</a>
    </div>

    <div class="entity-block game-table-wrap">
        <div class="entity-header">Review list (@Model.Count)</div>
        <div class="table-responsive">
            <table class="table game-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Rating</th>
                        <th>Game</th>
                        <th>User</th>
                        <th>Recommended</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td>@review.Review.Title</td>
                            <td>@review.Review.Rating</td>
                            <td>@review.GameName</td>
                            <td>@review.Username</td>
                            <td>@(review.Review.IsRecommended ? "Yes" : "No")</td>
                            <td>@review.Review.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@review.Review.Id" class="btn btn-sm game-btn-primary">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
