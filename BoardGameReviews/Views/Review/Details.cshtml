@model BoardGameReviews.Models.ReviewDetailsViewModel

@{
    ViewData["Title"] = "Review Details";
}

<section class="game-page game-details-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Entity Details</p>
            <h1 class="mb-0">@Model.Review.Title</h1>
        </div>
        <a asp-action="Index" class="btn game-btn-outline">Back to Reviews</a>
    </div>

    <div class="card game-card">
        <div class="card-header">Review</div>
        <div class="card-body">
            <p><strong>Game:</strong> @Model.Game?.Name</p>
            <p><strong>User:</strong> @Model.User?.Username</p>
            <p><strong>Rating:</strong> @Model.Review.Rating / 5</p>
            <p><strong>Recommended:</strong> @(Model.Review.IsRecommended ? "Yes" : "No")</p>
            <p><strong>Date:</strong> @Model.Review.CreatedAt.ToString("g")</p>
            <p class="mb-0"><strong>Comment:</strong> @Model.Review.Comment</p>
        </div>
    </div>
</section>
