@model BoardGameReviews.Models.UserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
}

<section class="game-page game-details-page">
    <div class="game-hero mb-4 d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <p class="eyebrow mb-2">Entity Details</p>
            <h1 class="mb-0">@Model.User.Username</h1>
        </div>
        <a asp-action="Index" class="btn game-btn-outline">Back to Users</a>
    </div>

    <div class="card game-card mb-4">
        <div class="card-header">User</div>
        <div class="card-body">
            <p><strong>Email:</strong> @Model.User.Email</p>
            <p><strong>Country:</strong> @Model.User.Country</p>
            <p class="mb-0"><strong>Age:</strong> @Model.User.Age</p>
        </div>
    </div>

    <div class="card game-card">
        <div class="card-header">User Reviews</div>
        <div class="card-body">
            @if (Model.Reviews.Count == 0)
            {
                <p class="mb-0">No reviews found for this user.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table game-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Game</th>
                                <th>Rating</th>
                                <th>Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model.Reviews)
                            {
                                <tr>
                                    <td>@review.Review.Title</td>
                                    <td>@review.GameName</td>
                                    <td>@review.Review.Rating</td>
                                    <td>@review.Review.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <a asp-controller="Review" asp-action="Details" asp-route-id="@review.Review.Id" class="btn btn-sm game-btn-outline">Open Review</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
