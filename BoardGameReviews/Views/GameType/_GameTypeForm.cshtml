@model BoardGameReviews.Models.GameTypeFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

@await Html.PartialAsync("_AiFormPrompt", new BoardGameReviews.Models.AiFormPromptViewModel
{
    EntityType = "gametype",
    Title = "Generate game type data",
    Placeholder = "Example: Create a tile placement game type with a short description."
})

<div class="game-form-grid">
    <div>
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>

    <div class="game-form-grid__full">
        <label asp-for="Input.Description" class="form-label"></label>
        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>
    </div>
</div>

<div class="game-form-actions">
    <button type="submit" class="btn game-btn-primary">@(Model.IsEdit ? "Save Changes" : "Create Game Type")</button>
    <a asp-action="Index" class="btn game-btn-outline">Back to List</a>
</div>
