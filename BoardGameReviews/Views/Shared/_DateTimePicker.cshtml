@model BoardGameReviews.Models.DateTimePickerViewModel

@{
    var isoValue = Model.Value.HasValue ? Model.Value.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty;
    var hasError = !string.IsNullOrWhiteSpace(Model.ValidationMessage);
       var inputClass = hasError ? "field-missing" : string.Empty;
}

<div class="dtp-picker"
     data-dtp
     data-field-name="@Model.FieldName"
     data-required="@(Model.IsRequired ? "true" : "false")"
        data-required-message="@Model.RequiredErrorMessage">

       <label class="form-label" for="@(Model.FieldId)_trigger">@Model.Label</label>

    @* Hidden input carries the ISO value for model binding *@
    <input type="hidden"
           name="@Model.FieldName"
           id="@Model.FieldId"
           value="@isoValue"
           data-dtp-hidden />

       <button type="button"
                     class="form-control dtp-trigger @inputClass"
                     id="@(Model.FieldId)_trigger"
                     data-dtp-trigger
                     aria-expanded="false"
                     aria-controls="@(Model.FieldId)_panel">
              <span class="dtp-trigger__value" data-dtp-summary>@(Model.Value.HasValue ? Model.Value.Value.ToString("g") : string.Empty)</span>
              <span class="dtp-trigger__meta">▾</span>
       </button>

       <div class="dtp-panel" id="@(Model.FieldId)_panel" data-dtp-panel hidden role="dialog" aria-label="@Model.Label picker">
              <div class="dtp-panel__grid">
                     <section class="dtp-section dtp-section--calendar">
                            <div class="dtp-section__header">
                                   <button type="button" class="dtp-nav-btn" data-dtp-prev aria-label="Previous month">‹</button>
                                   <div class="dtp-section__title" data-dtp-month-label></div>
                                   <button type="button" class="dtp-nav-btn" data-dtp-next aria-label="Next month">›</button>
                            </div>
                            <div class="dtp-year-fine" role="group" aria-label="Year controls">
                                   <button type="button" class="dtp-year-fine__btn" data-dtp-year-minus aria-label="Year minus one">-</button>
                                   <input type="text"
                                          class="dtp-year-fine__input"
                                          inputmode="numeric"
                                          maxlength="4"
                                          placeholder="2026"
                                          data-dtp-year-input
                                          aria-label="Year value" />
                                   <button type="button" class="dtp-year-fine__btn" data-dtp-year-plus aria-label="Year plus one">+</button>
                            </div>
                            <div class="dtp-day-fine" role="group" aria-label="Day controls">
                                   <button type="button" class="dtp-day-fine__btn" data-dtp-day-minus aria-label="Day minus one">-</button>
                                   <input type="text"
                                          class="dtp-day-fine__input"
                                          inputmode="numeric"
                                          maxlength="2"
                                          placeholder="01"
                                          data-dtp-day-input
                                          aria-label="Day value" />
                                   <button type="button" class="dtp-day-fine__btn" data-dtp-day-plus aria-label="Day plus one">+</button>
                            </div>
                            <div class="dtp-weekdays" data-dtp-weekdays></div>
                            <div class="dtp-day-grid" data-dtp-days></div>
                     </section>

                     <section class="dtp-section dtp-section--clock">
                            <div class="dtp-section__header dtp-section__header--stacked">
                                   <div class="dtp-section__title">Time</div>
                                   <div class="dtp-period-toggle" role="group" aria-label="AM PM toggle">
                                          <button type="button" class="dtp-period-toggle__btn" data-dtp-am>AM</button>
                                          <button type="button" class="dtp-period-toggle__btn" data-dtp-pm>PM</button>
                                   </div>
                            </div>

                            <div class="dtp-clock-stack">
                                   <div class="dtp-clock-card">
                                          <div class="dtp-clock-card__title">Hours</div>
                                          <div class="dtp-clock" data-dtp-hour-clock>
                                                 <div class="dtp-clock__center" data-dtp-hour-display>--</div>
                                          </div>
                                          <div class="dtp-hour-fine" role="group" aria-label="Hour controls">
                                                 <button type="button" class="dtp-hour-fine__btn" data-dtp-hour-minus aria-label="Hour minus one">-</button>
                                                 <input type="text"
                                                        class="dtp-hour-fine__input"
                                                        inputmode="numeric"
                                                        maxlength="2"
                                                        placeholder="12"
                                                        data-dtp-hour-input
                                                        aria-label="Hour value" />
                                                 <button type="button" class="dtp-hour-fine__btn" data-dtp-hour-plus aria-label="Hour plus one">+</button>
                                          </div>
                                   </div>

                                   <div class="dtp-clock-card">
                                          <div class="dtp-clock-card__title">Minutes</div>
                                          <div class="dtp-clock dtp-clock--minutes" data-dtp-minute-clock>
                                                 <div class="dtp-clock__center" data-dtp-minute-display>--</div>
                                          </div>
                                          <div class="dtp-minute-fine" role="group" aria-label="Minute controls">
                                                 <button type="button" class="dtp-minute-fine__btn" data-dtp-minute-minus aria-label="Minute minus one">-</button>
                                                 <input type="text"
                                                        class="dtp-minute-fine__input"
                                                        inputmode="numeric"
                                                        maxlength="2"
                                                        placeholder="00"
                                                        data-dtp-minute-input
                                                        aria-label="Minute value" />
                                                 <button type="button" class="dtp-minute-fine__btn" data-dtp-minute-plus aria-label="Minute plus one">+</button>
                                          </div>
                                   </div>
                            </div>
                     </section>
              </div>

              <div class="dtp-panel__footer">
                     <button type="button" class="btn dtp-panel__button dtp-panel__button--ghost" data-dtp-today>Today</button>
                     <button type="button" class="btn dtp-panel__button dtp-panel__button--ghost" data-dtp-clear>Clear</button>
                     <button type="button" class="btn dtp-panel__button game-btn-primary" data-dtp-close>Done</button>
              </div>
    </div>

       <span class="text-danger @(hasError ? "field-validation-error" : "field-validation-valid")"
                data-dtp-validation>@Model.ValidationMessage</span>
</div>
