<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BoardGameReviews</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/game.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="site-header">
        <div class="page-container">
            <nav class="site-nav" aria-label="Main navigation">
                <a class="site-brand" asp-area="" asp-controller="Home" asp-action="Index">BoardGameReviews</a>
                <ul class="site-nav-links">
                    <li><a class="site-nav-link" data-controller="home" data-route="" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="site-nav-link" data-controller="home" data-route="privacy" data-action="privacy" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    <li><a class="site-nav-link" data-controller="game" data-route="games" asp-area="" asp-controller="Game" asp-action="Index">Games</a></li>
                    <li><a class="site-nav-link" data-controller="category" data-route="categories" asp-area="" asp-controller="Category" asp-action="Index">Categories</a></li>
                    <li><a class="site-nav-link" data-controller="gametype" data-route="game-types" asp-area="" asp-controller="GameType" asp-action="Index">Types</a></li>
                    <li><a class="site-nav-link" data-controller="publisher" data-route="publishers" asp-area="" asp-controller="Publisher" asp-action="Index">Publishers</a></li>
                    <li><a class="site-nav-link" data-controller="user" data-route="users" asp-area="" asp-controller="User" asp-action="Index">Users</a></li>
                    <li><a class="site-nav-link" data-controller="review" data-route="reviews" asp-area="" asp-controller="Review" asp-action="Index">Reviews</a></li>
                    <li><a class="site-nav-link" data-controller="event" data-route="events" asp-area="" asp-controller="Event" asp-action="Index">Events</a></li>
                </ul>
                <partial name="_LoginPartial" />
            </nav>
        </div>
    </header>

    <main role="main" class="site-main">
        <div class="page-container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="page-container">
            &copy; 2026 - BoardGameReviews - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
