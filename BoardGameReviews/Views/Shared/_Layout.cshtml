<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BoardGameReviews</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/game.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="site-header">
        <div class="page-container">
            <nav class="site-nav" aria-label="Main navigation">
                <a class="site-brand" asp-area="" asp-controller="Home" asp-action="Index">BoardGameReviews</a>
                <ul class="site-nav-links">
                    <li><a class="site-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="site-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    <li><a class="site-nav-link" asp-area="" asp-controller="Game" asp-action="Index">Games</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main role="main" class="site-main">
        <div class="page-container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="page-container">
            &copy; 2026 - BoardGameReviews - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
